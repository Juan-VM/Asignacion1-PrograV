@model EmployeePageViewModel

@{
    ViewData["Title"] = "Employees";
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">
            Human Resources Portal
        </h1>

        <p class="text-muted fs-5">
            Employee and Department Information
        </p>

        <span class="badge bg-secondary px-3 py-2 fs-6">
            Total Employees: @Model.Employees.Count()
        </span>
    </div>

    <div class="card shadow-sm mb-4">

        <div class="card-header bg-light">
            <strong>Search Filters</strong>
        </div>

        <div class="card-body">

            <form method="get">

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Employee Name</label>

                        <input type="text"
                               name="name"
                               value="@Model.Filters.Name"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Department</label>

                        <input type="text"
                               name="department"
                               value="@Model.Filters.Department"
                               class="form-control" />
                    </div>

                </div>

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <label>Job Title</label>

                        <input type="text"
                               name="jobTitle"
                               value="@Model.Filters.JobTitle"
                               class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Shift</label>

                        <input type="text"
                               name="shift"
                               value="@Model.Filters.Shift"
                               class="form-control" />
                    </div>

                </div>

                <div class="row align-items-center">

                    <div class="col-md-6">

                        <div class="form-check">

                            <input class="form-check-input"
                                   type="checkbox"
                                   name="onlyActive"
                                   value="true"
                            @(Model.Filters.OnlyActive ? "checked" : "") />

                            <label class="form-check-label">
                                Only Active Employees
                            </label>

                        </div>

                    </div>

                    <div class="col-md-6 text-end">

                        <button type="submit"
                                class="btn btn-primary">

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <div class="card shadow border-0">
        <div class="card-header bg-secondary text-white text-center">
            <h5 class="mb-0">
                Employee Directory
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Employee Name</th>
                            <th>Job Title</th>
                            <th>Department</th>
                            <th>Shift</th>
                            <th>Status</th>
                        </tr>
                    </thead>

                    <tbody>

                        @if (!Model.Employees.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-4 text-muted">
                                    No employees found.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var emp in Model.Employees)
                            {
                                <tr>
                                    <td class="fw-bold text-secondary">
                                        @emp.BusinessEntityID
                                    </td>
                                    <td>
                                        <span class="fw-semibold">
                                            @emp.FullName
                                        </span>
                                    </td>
                                    <td>
                                        @emp.JobTitle
                                    </td>
                                    <td>
                                        <span class="text-dark">
                                            @emp.Department
                                        </span>
                                    </td>
                                    <td>
                                        @emp.ShiftName
                                    </td>
                                    <td>
                                        @if (emp.ActiveEmployee)
                                        {
                                            <span class="badge bg-success">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                Inactive
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>